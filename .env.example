# Database connection used by the test suite.
# Leave as "testing" for the in-memory sqlite default, or switch to
# "mysql" / "pgsql" to run the suite against a real server.
DB_CONNECTION=testing

# Only used when DB_CONNECTION is mysql or pgsql.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=testing
DB_USERNAME=root
DB_PASSWORD=